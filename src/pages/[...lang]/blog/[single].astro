---
import CallToAction from "@/components/sections/CallToAction.astro";
import Base from "@/layouts/Base.astro";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import config from ".astro/config.generated.json" assert { type: "json" };
import { getEntryCTM } from "@/lib/contentParser.astro";
import { supportedLanguages } from "@/lib/utils/i18nUtils";
import BlogSinglePageLayout from "@/components/BlogSinglePageLayout.astro";
import { slugifyyy } from "@/lib/utils/textConverter";
import buildToc from "@/lib/utils/buildToc";
import { render } from "astro:content";

export async function getStaticPaths() {
  const paths = await Promise.all(
    supportedLanguages.map(async (lang) => {
      const { blogFolder } = config.settings;
      const { defaultLanguage, showDefaultLangInUrl } =
        config.settings.multilingual;

      const postIndex = await getEntryCTM(
        blogFolder as "blog",
        "-index",
        lang.languageCode,
      );

      let posts = await getCollectionCTM(
        blogFolder as "blog",
        lang.languageCode,
      );

      // If draft true in index.md file frontmatter don't include any page related to this page collection in production
      if (postIndex?.data.draft && import.meta.env.PROD) {
        return [];
      }

      return posts.map((post) => ({
        params: {
          lang:
            lang.languageCode === defaultLanguage && !showDefaultLangInUrl
              ? undefined
              : lang.languageCode,
          single:
            post.data?.customSlug ||
            post.id
              .replace(/\.mdx?|\.md/g, "")
              .split("/")
              .pop(),
        },
        props: {
          post,
          postIndex,
        },
      }));
    }),
  );

  return paths.flat();
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { tableOfContents } = config.settings.markup;

const { author } = post?.data || {};

let tocHeadings;

// Get Author Details
let authorEntry = [];
if (author) {
  const slug = slugifyyy(author);
  const entry = await getEntryCTM("author", slug, Astro.currentLocale);
  authorEntry = entry?.data || [];
}

// Generate table of contents
if (headings) {
  tocHeadings = buildToc(headings);
}

const ctaContent = {
  enable: true,
  title: "Stay Informed with **Expert Insights**",
  description:
    "Discover the latest trends in ERP, AI, and digital transformation from our certified technology experts.",
  background: "/src/assets/images/cta/cta-blog.png",
  button: {
    enable: true,
    label: "SCHEDULE A FREE CONSULTATION",
    url: "/contact/",
    hoverEffect: "text-flip",
  },
  stats: {
    title: "100+",
    description: "Resources to boost <br /> your growth",
    avatars: [
      "/images/customers/avatar/1.jpg",
      "/images/customers/avatar/2.jpg",
      "/images/customers/avatar/3.jpg",
    ],
  },
};
---

<Base {...post.data}>
  <BlogSinglePageLayout
    content={{
      ...post.data,
      tableOfContents,
      tocHeadings,
      author: authorEntry,
      Content,
    }}
  />
  <CallToAction content={ctaContent} />
</Base>
