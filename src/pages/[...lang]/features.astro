---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import { getEntryCTM } from "@/lib/contentParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import CallToAction from "@/components/sections/CallToAction.astro";
import FeaturesSection from "@/components/sections/FeaturesGrid.astro";
import TestimonialSection from "@/components/sections/TestimonialSection.astro";
import FeaturesSectionTwo from "@/components/sections/FeaturesSectionTwo.astro";
import FeaturesSectionFour from "@/components/sections/FeaturesSectionFour.astro";
import FeaturesSectionThree from "@/components/sections/FeaturesRingLayout.astro";

export function getStaticPaths() {
  return generatePaths();
}

const entry = await getEntryCTM("features", "-index", Astro.currentLocale);

// Remove drafts pages in production
const response = handleDraftPage(entry?.data);
if (response) return response;

const ctaContent = {
  enable: true,
  title: "Experience the **Full Potential of Odoo**",
  description:
    "Explore the comprehensive features that make Odoo the world's most popular business platform.",
  background: "/src/assets/images/cta/cta-features.png",
  button: {
    enable: true,
    label: "SCHEDULE A FREE CONSULTATION",
    url: "/contact/",
    hoverEffect: "text-flip",
  },
  stats: {
    title: "82+",
    description: "Integrated apps <br /> within Odoo",
    avatars: [
      "/images/customers/avatar/1.jpg",
      "/images/customers/avatar/2.jpg",
      "/images/customers/avatar/3.jpg",
    ],
  },
};
---

<Base {...entry?.data} hasGradientShape={false}>
  <FeaturesSection />
  <FeaturesSectionTwo />
  <FeaturesSectionThree />
  <FeaturesSectionFour />
  <TestimonialSection />
  <CallToAction content={ctaContent} />
</Base>
