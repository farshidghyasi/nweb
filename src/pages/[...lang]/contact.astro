---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import { generatePaths } from "@/lib/utils/i18nUtils";
import CallToAction from "@/components/sections/CallToAction.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import TestimonialSection from "@/components/sections/TestimonialSection.astro";
import StatsTwo from "@/components/sections/FunFactTwo.astro";

export function getStaticPaths() {
  return generatePaths();
}

const contactIndex = await getEntryCTM(
  "contact",
  "-index",
  Astro.currentLocale,
);

// Remove drafts pages in production
const response = handleDraftPage(contactIndex?.data);
if (response) return response;

const ctaContent = {
  enable: true,
  title: "Let's Build **Something Great Together**",
  description: "Ready to take the next step? Our experts are here to help you design and implement the perfect solution.",
  background: "/src/assets/images/cta/cta-contact.png",
  button: { enable: true, label: "SCHEDULE A FREE CONSULTATION", url: "/contact/", hoverEffect: "text-flip" },
  stats: { title: "24hr", description: "Average response <br /> time", avatars: ["/images/customers/avatar/1.jpg", "/images/customers/avatar/2.jpg", "/images/customers/avatar/3.jpg"] },
};
---

<Base {...contactIndex?.data}>
  <ContactSection />
  <TestimonialSection />
  <StatsTwo />
  <CallToAction content={ctaContent} />
</Base>
