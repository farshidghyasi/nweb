---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import PageHeader from "@/components/PageHeader.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import CallToAction from "@/components/sections/CallToAction.astro";
import config from ".astro/config.generated.json" with { type: "json" };
import IntegrationList from "@/components/sections/IntegrationList.astro";

export function getStaticPaths() {
  return generatePaths();
}

const entry = await getEntryCTM(
  config.settings.integrationFolder as "integration",
  "-index",
  Astro.currentLocale,
);

// Remove drafts pages in production
const response = handleDraftPage(entry?.data);
if (response) return response;

const ctaContent = {
  enable: true,
  title: "Expert Services. **Exceptional Results.**",
  description:
    "From ERP implementation to custom software and AI automation, our certified experts deliver technology that works.",
  background: "/src/assets/images/cta/cta-services.png",
  button: {
    enable: true,
    label: "SCHEDULE A FREE CONSULTATION",
    url: "/contact/",
    hoverEffect: "text-flip",
  },
  stats: {
    title: "400+",
    description: "Certified experts <br /> around the world",
    avatars: [
      "/images/customers/avatar/1.jpg",
      "/images/customers/avatar/2.jpg",
      "/images/customers/avatar/3.jpg",
    ],
  },
};

let integrationsCategories = await getTaxonomy(
  config.settings.integrationFolder as "integration",
  "categories",
  Astro.currentLocale,
);

// Remove category that defined in integration -index.md under sections frontmatter
if (entry?.data.sections) {
  entry.data.sections.forEach((section) => {
    if (section.category) {
      integrationsCategories = integrationsCategories.filter(
        (category) => category.name !== section.category,
      );
    }
  });
}
---

<Base {...entry?.data}>
  <PageHeader {...entry?.data} />
  <IntegrationList data-aos="fade-up-sm" data-aos-delay="300" />
  <CallToAction content={ctaContent} />
</Base>
