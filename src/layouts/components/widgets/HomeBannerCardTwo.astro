---
import { markdownify } from "@/lib/utils/textConverter";
import Icons from "@/helpers/Icons.astro";
import type { TypeOf } from "astro/zod";
import type { heroSectionSchema } from "@/sections.schema";

interface Props {
  content: TypeOf<typeof heroSectionSchema>["rightBlock"];
  [key: string]: any;
}

const { content, ...rest } = Astro.props;
const { enable, icons, title, description, author } = Astro.props.content || {};

if (!enable) return;
---

<div {...rest}>
  <div class="mb-4 flex gap-1">
    {
      icons?.map((icon) => (
        <div class="flex h-5 w-5 items-center justify-center bg-green-600">
          <Icons icon={icon as any} class="fill-white text-xs text-white" />
        </div>
      ))
    }
  </div>

  {
    title && (
      <h2
        class="lg:text-h4 h4 sm:text-h6 mb-4 font-medium"
        set:html={markdownify(title)}
      />
    )
  }

  {description && <p set:html={markdownify(description)} />}

  {
    author && (
      <p
        class="mt-3 border-t pt-3 text-sm font-medium text-gray-900"
        set:html={markdownify(author)}
      />
    )
  }
</div>
