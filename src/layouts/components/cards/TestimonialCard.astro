---
import { markdownify } from "@/lib/utils/textConverter";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";

let {
  enable,
  platform,
  rating: ratingNumber,
  customer,
  content,
} = Astro.props.content as any;

const rating = new Array(ratingNumber).fill(null) as number[];

if (!enable) return;
---

<div
  class:list={[
    "flex min-h-full w-full flex-col items-start rounded-lg border p-6",
    Astro.props.class,
  ]}>
  <div class="flex flex-col items-start space-y-10">
    <div class="flex items-center space-x-4">
      {
        rating && (
          <div class="inline-flex border-e pe-3">
            {rating.map((_) => (
              <svg
                class="h-8 w-8 fill-current text-yellow-500"
                viewBox="0 0 20 20"
                fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        )
      }
      {
        platform?.icon && (
          <OptimizedImage
            class="h-6 w-6"
            src={platform.icon}
            alt={platform.name}
          />
        )
      }
    </div>
    {
      content && (
        <blockquote
          class="text-lg leading-relaxed"
          set:html={markdownify(content)}
        />
      )
    }
  </div>

  <div
    class="mt-auto flex w-full flex-col-reverse gap-4 sm:flex-row sm:items-center">
    <div class="flex items-center gap-4 max-sm:border-t max-sm:pt-6">
      {
        customer.avatar && (
          <OptimizedImage
            src={customer.avatar}
            alt={customer.name}
            class="h-16 w-16 rounded-lg border-4 object-cover"
          />
        )
      }
      <div class="me-2 min-w-0 flex-1 space-y-1 sm:border-e sm:pe-6">
        {
          customer.name && (
            <div class="text-lg font-medium text-black">{customer.name}</div>
          )
        }
        {customer.role && <p class="text-sm">{customer.role}</p>}
      </div>
    </div>
    {
      customer.companyLogo && (
        <OptimizedImage src={customer.companyLogo} class="w-10" />
      )
    }
  </div>
</div>
