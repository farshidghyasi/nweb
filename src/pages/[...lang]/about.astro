---
import Base from "@/layouts/Base.astro";
import Team from "@/components/sections/Team.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import { getEntryCTM } from "@/lib/contentParser.astro";
import AboutUs from "@/components/sections/AboutUs.astro";
import Customers from "@/components/sections/Customers.astro";
import FunFactTwo from "@/components/sections/FunFactTwo.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import FeaturesSectionTwo from "@/components/sections/FeaturesSectionTwo.astro";

export function getStaticPaths() {
  return generatePaths();
}

const about = await getEntryCTM("about", "-index", Astro.currentLocale);

const ctaContent = {
  enable: true,
  title: "Partner with **20 Years of Excellence**",
  description:
    "Join 5,000+ organizations that trust NETLINKS for their technology transformation. Let's talk about your goals.",
  background: "/src/assets/images/cta/cta-about.png",
  button: {
    enable: true,
    label: "SCHEDULE A CONSULTATION",
    url: "/contact/",
    hoverEffect: "text-flip",
  },
  stats: {
    title: "400+",
    description: "Certified experts <br /> ready to help",
    avatars: [
      "/images/customers/avatar/1.jpg",
      "/images/customers/avatar/2.jpg",
      "/images/customers/avatar/3.jpg",
    ],
  },
};
---

<Base {...about.data}>
  <AboutUs />
  <FunFactTwo />
  <FeaturesSectionTwo variant="white" />
  <Customers data-aos="fade-up-sm" tag="section" variant="grey" />
  <Team variant="white" />
  <CallToAction content={ctaContent} />
</Base>
