---
// src/layouts/components/widgets/AnimatedText.astro
import type { HTMLTag } from "astro/types";

type Props = {
  class?: string;
  content: string | Promise<string>;
  duration?: number;
  delay?: number;
  tag?: HTMLTag;
  stagger?: number;
};

let {
  content,
  tag: Element = "div",
  duration = 0.6,
  delay = 0,
  stagger = 0.1,
  ...rest
} = Astro.props;

let processedContent = "";
if (content) {
  // Split content into HTML tags and text segments
  // @ts-expect-error
  const parts = content.split(/(<[^>]+>)/g);

  processedContent = parts
    .map((part: string) => {
      // If it's an HTML tag, return as-is
      if (part.startsWith("<") && part.endsWith(">")) {
        return part;
      }

      // If it's text, wrap each word
      if (part.trim()) {
        return part
          .split(/(\s+)/) // Split by whitespace, keeping the whitespace
          .map((segment: string) => {
            // If it's whitespace, return as-is
            if (/^\s+$/.test(segment)) {
              return segment;
            }
            // If it's a word, wrap it
            if (segment.trim()) {
              return `<span class="word" style="display: inline-block; will-change: transform; transform: translateY(10px); opacity: 0; filter: blur(10px);">${segment}</span>`;
            }
            return segment;
          })
          .join("");
      }

      return part;
    })
    .join("");
}
---

<Element
  class:list={["animated-text", Astro.props.class]}
  set:html={processedContent}
  data-duration={duration}
  data-delay={delay}
  data-stagger={stagger}
  {...rest}
/>

<script>
  import { animate, stagger, inView } from "motion";

  const animatedTexts = document.querySelectorAll(".animated-text");

  animatedTexts.forEach((animatedText) => {
    const duration = parseFloat(
      animatedText.getAttribute("data-duration") as string,
    );
    const delay = parseFloat(animatedText.getAttribute("data-delay") as string);
    const dataStagger = parseFloat(
      animatedText.getAttribute("data-stagger") as string,
    );

    inView(animatedText, (element: any) => {
      const words = element.querySelectorAll(".word");
      let animation = animate(
        words,
        { opacity: 1, y: 0, filter: "blur(0px)" },
        {
          duration: duration,
          delay: stagger(dataStagger, { startDelay: delay }),
          ease: "easeOut",
        },
      );

      // This will fire when the element leaves the viewport
      // return () => {
      //   animation.stop();
      //   animate(element.querySelectorAll(".word"), {
      //     opacity: 0,
      //     y: 20,
      //     filter: "blur(10px)",
      //   });
      // };
    });
  });
</script>
