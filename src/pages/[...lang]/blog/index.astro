---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import { getEntryCTM } from "@/lib/contentParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import removeEmptyKeys from "@/lib/utils/removeEmptyKeys";
import BlogSection from "@/components/sections/BlogSection.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import config from ".astro/config.generated.json" with { type: "json" };

export function getStaticPaths() {
  return generatePaths();
}

const { blogFolder } = config.settings;

const postIndex = await getEntryCTM(
  blogFolder as "blog",
  "-index",
  Astro.currentLocale,
);

// Remove drafts pages in production
const response = handleDraftPage(postIndex?.data);
if (response) return response;

const ctaContent = {
  enable: true,
  title: "Stay Informed with **Expert Insights**",
  description: "Discover the latest trends in ERP, AI, and digital transformation from our certified technology experts.",
  background: "/src/assets/images/cta/cta-blog.png",
  button: { enable: true, label: "SCHEDULE A FREE CONSULTATION", url: "/contact/", hoverEffect: "text-flip" },
  stats: { title: "100+", description: "Resources to boost <br /> your growth", avatars: ["/images/customers/avatar/1.jpg", "/images/customers/avatar/2.jpg", "/images/customers/avatar/3.jpg"] },
};
---

<Base {...postIndex?.data} fitToScreen={false}>
  <BlogSection
    content={{
      ...removeEmptyKeys(postIndex.data),
    }}
    listPage={true}
    pagination={{ enable: true, currentPage: 1 }}
  />
  <CallToAction content={ctaContent} />
</Base>
