---
import { markdownify } from "@/lib/utils/textConverter";
import OptimizedImage from "../utilities/OptimizedImage.astro";
import Icons from "@/helpers/Icons.astro";
import type { TypeOf } from "astro/zod";
import type { heroSectionSchema } from "@/sections.schema";

interface Props {
  content: TypeOf<typeof heroSectionSchema>["leftBlock"];
  [key: string]: any;
}

const { content, ...rest } = Astro.props;
const { enable, icon, title, description, images } = Astro.props.content || {};

if (!enable) return;
---

<div {...rest}>
  <svg width="0" height="0" class="absolute">
    <defs>
      <linearGradient
        id="paint0_linear_17112_6337"
        x1="24"
        y1="4"
        x2="24"
        y2="44.0067"
        gradientUnits="userSpaceOnUse">
        <stop stop-color="var(--color-secondary)"></stop>
        <stop offset=".5" stop-color="white"></stop>
      </linearGradient>
    </defs>
  </svg>

  {
    icon && (
      <Icons
        icon={icon as any}
        class="mb-4 text-5xl [&_path]:stroke-[url(#paint0_linear_17112_6337)]"
      />
    )
  }

  {
    title && (
      <h2
        class="lg:text-h4 h4 sm:text-h6 mb-4 font-medium"
        set:html={markdownify(title)}
      />
    )
  }

  {
    description && (
      <p class="mb-6 md:mb-8" set:html={markdownify(description)} />
    )
  }

  <div class="flex items-center justify-center gap-3">
    {
      images?.map((item) => (
        <div class="bg-primary/5 flex h-11 w-11 items-center justify-center rounded-full">
          <OptimizedImage
            src={item.image}
            alt={item.name}
            width={100}
            height={40}
            class="h-6 w-auto"
          />
        </div>
      ))
    }
  </div>
</div>
