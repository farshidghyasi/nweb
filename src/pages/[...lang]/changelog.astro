---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import ChangelogSection from "@/components/widgets/ChangelogContent.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import SinglePageLayout from "@/components/SinglePageLayout.astro";
import PageHeader from "@/components/PageHeader.astro";

export function getStaticPaths() {
  return generatePaths();
}

const changelogListPage = await getEntryCTM(
  "changelog",
  "-index",
  Astro.currentLocale,
);

// Remove drafts pages in production
const response = handleDraftPage(changelogListPage?.data);
if (response) return response;

const ctaContent = {
  enable: true,
  title: "Stay Ahead with **Continuous Innovation**",
  description:
    "Explore our latest updates and features. We're constantly evolving Odoo to better serve your business needs.",
  background: "/src/assets/images/cta/cta-changelog.png",
  button: {
    enable: true,
    label: "SCHEDULE A FREE CONSULTATION",
    url: "/contact/",
    hoverEffect: "text-flip",
  },
  stats: {
    title: "20+",
    description: "Years of continuous <br /> innovation",
    avatars: [
      "/images/customers/avatar/1.jpg",
      "/images/customers/avatar/2.jpg",
      "/images/customers/avatar/3.jpg",
    ],
  },
};
---

<Base {...changelogListPage?.data}>
  <PageHeader {...changelogListPage?.data} />
  <SinglePageLayout
    class="pt-12"
    innerPadding="sm"
    data-aos="fade-up-sm"
    data-aos-delay="200">
    <ChangelogSection listPage={true} slot="content" />
  </SinglePageLayout>
  <CallToAction content={ctaContent} />
</Base>
