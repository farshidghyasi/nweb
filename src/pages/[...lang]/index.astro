---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import { getEntryCTM } from "@/lib/contentParser.astro";
import FunFact from "@/components/sections/FunFact.astro";
import HomeBanner from "@/components/sections/HomeBanner.astro";
import FeaturesGrid from "@/components/sections/FeaturesGrid.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import InsightSection from "@/components/sections/InsightSection.astro";
import TestimonialSection from "@/components/sections/TestimonialSection.astro";
import FeaturesSectionFour from "@/components/sections/FeaturesSectionFour.astro";

export function getStaticPaths() {
  return generatePaths();
}

const homepage = await getEntryCTM("homepage", "-index", Astro.currentLocale);

const ctaContent = {
  enable: true,
  title: "Ready to Transform Your Business with **Technology That Works?**",
  description: "Join 4,500+ organizations worldwide that trust NETLINKS to power their digital transformation.",
  background: "/src/assets/images/cta/cta-home.png",
  button: { enable: true, label: "SCHEDULE A FREE CONSULTATION", url: "/contact/", hoverEffect: "text-flip" },
  stats: { title: "4,500+", description: "Clients served <br /> worldwide", avatars: ["/images/customers/avatar/1.jpg", "/images/customers/avatar/2.jpg", "/images/customers/avatar/3.jpg"] },
};
---

<Base {...homepage.data} homepage={true} hasGradientShape={false}>
  <HomeBanner />
  <FunFact />
  <FeaturesGrid variant="grey" />
  <FeaturesSectionFour />
  <InsightSection variant="grey" />
  <TestimonialSection />
  <CallToAction content={ctaContent} />
</Base>
