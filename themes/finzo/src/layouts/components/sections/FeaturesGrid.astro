---
import type { Section } from "@/types";
import type { TypeOf } from "astro:schema";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import type { featuresSectionSchema } from "@/sections.schema";
import OptimizedImage from "../utilities/OptimizedImage.astro";
import AnimatedText from "../widgets/AnimatedText.astro";

// Type for this section data
type SectionType = Section & TypeOf<typeof featuresSectionSchema>;
type Props = {
  content?: SectionType;
};

// Fetching the default content for the this section
let defaultContent = (
  await getEntryCTM("sections", "features-grid", Astro.currentLocale)
)?.data as SectionType;

// Enables content customization (e.g., title, description) with a fallback to 'defaultContent' if not provided.
// The 'content' prop should match the structure of 'defaultContent'.
// Allows using this section with different content across multiple pages.
// If 'content' is missing, 'defaultContent' will be used.
let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as SectionType;

// Extracting required values from 'content' object
let {
  enable = true,
  title,
  description,
  featureListLimit,
  list,
} = actualContent as SectionType;

// detect feature list page and if not limit the feature list
let isFeatureListPage = Astro.url.pathname.includes("/features/");
if (featureListLimit && !isFeatureListPage) {
  list = list.slice(0, featureListLimit);
}

if (!enable) return;
---

<section>
  <div class="container space-y-10 md:space-y-16">
    {
      title && (
        <div class="mx-auto space-y-4 text-center">
          <h2 class="has-italic-text capitalize">
            <AnimatedText
              delay={0.2}
              stagger={0.09}
              content={markdownify(title)}
            />
          </h2>

          {description && (
            <AnimatedText
              tag="p"
              delay={0.5}
              duration={0.7}
              stagger={0.0009}
              content={markdownify(description)}
            />
          )}
        </div>
      )
    }
    {
      list && (
        <div class="grid gap-12 md:grid-cols-6">
          {list.map((item, index) => (
            <div
              data-aos="fade-up-sm"
              data-aos-delay={(index + 1) * 100}
              class:list={[
                "bg-theme-light flex flex-col justify-between rounded-xl px-7 pt-7",
                item.halfWidth
                  ? "sm:col-span-3"
                  : "sm:col-span-3 lg:col-span-2",
              ]}>
              {item.image && (
                <OptimizedImage
                  src={item.image}
                  class:list={[
                    "mx-auto block rounded-t-xl",
                    item.alternativeDirection && "order-2",
                  ]}
                  alt={item.title}
                />
              )}
              <div
                class:list={[
                  "space-y-4",
                  item.alternativeDirection ? "order-1 pb-10" : "pt-10",
                ]}>
                {item.title && (
                  <h3
                    class:list={[item.halfWidth ? "h4" : "h5"]}
                    set:html={markdownify(item.title)}
                  />
                )}
                {item.description && (
                  <p set:html={markdownify(item.description)} />
                )}
              </div>
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>
