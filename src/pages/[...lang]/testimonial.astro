---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import { getEntryCTM } from "@/lib/contentParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import removeEmptyKeys from "@/lib/utils/removeEmptyKeys";
import CallToAction from "@/components/sections/CallToAction.astro";
import TestimonialSection from "@/components/sections/TestimonialSection.astro";

export function getStaticPaths() {
  return generatePaths();
}

const testimonialListPage = await getEntryCTM(
  "testimonial",
  "-index",
  Astro.currentLocale,
);

// Remove drafts pages in production
const response = handleDraftPage(testimonialListPage?.data);
if (response) return response;

const ctaContent = {
  enable: true,
  title: "Ready to Be Our **Next Success Story?**",
  description:
    "Join the thousands of businesses that have transformed their operations with NETLINKS.",
  background: "/src/assets/images/cta/cta-testimonial.png",
  button: {
    enable: true,
    label: "SCHEDULE A FREE CONSULTATION",
    url: "/contact/",
    hoverEffect: "text-flip",
  },
  stats: {
    title: "5,000+",
    description: "Satisfied clients <br /> worldwide",
    avatars: [
      "/images/customers/avatar/1.jpg",
      "/images/customers/avatar/2.jpg",
      "/images/customers/avatar/3.jpg",
    ],
  },
};
---

<Base {...testimonialListPage?.data}>
  <TestimonialSection
    content={{
      layout: "grid",
      ...removeEmptyKeys(testimonialListPage.data),
    }}
    layout="grid"
  />
  <CallToAction content={ctaContent} />
</Base>
