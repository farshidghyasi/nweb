---
import Icons from "@/helpers/Icons.astro";
import CustomButton from "../CustomButton.astro";
import { markdownify } from "@/lib/utils/textConverter";
import AnimatedNumber from "../widgets/AnimatedNumber.astro";
import type { pricingSectionSchema } from "@/sections.schema";
import type { TypeOf } from "astro:schema";
import PricingToggle from "../widgets/PricingToggle.astro";
import Popover from "../widgets/Popover.astro";

type Comparison = NonNullable<TypeOf<typeof pricingSectionSchema>>;

type Props = {
  class?: string;
  content: Comparison & {
    selectedPlanIndex: number;
  };
};

const {
  class: className,
  content: {
    list,
    pricingComparisonTitle,
    pricingComparisonTogglerLabel,
    plans,
    comparison,
  },
} = Astro.props;

const selectedPlan = plans?.list?.find(
  (plan: { selected: boolean }) => plan.selected,
);
---

<div class:list={["container", className]}>
  <div
    data-aos="fade-up-sm"
    class:list={[
      "mx-auto mb-12 text-center md:mb-16 md:max-w-md",
      !pricingComparisonTitle && "sr-only",
    ]}>
    <h2
      class="has-italic-text capitalize"
      set:html={markdownify(pricingComparisonTitle || "Pricing Comparison")}
    />
  </div>
  <table
    data-aos="fade-up-sm"
    data-aos-delay={200}
    class="relative block w-full after:-top-40 after:-z-10 lg:table lg:table-fixed">
    <caption class="sr-only">Pricing Table Comparison</caption>
    <colgroup class="hidden lg:table-column-group">
      <col class="w-[300px] xl:w-[400px]" />
      <col class="w-[calc((100%-400px)/3)]" />
      <col class="w-[calc((100%-400px)/3)]" />
      <col class="w-[calc((100%-400px)/3)]" />
    </colgroup>
    <thead class="block lg:table-header-group">
      <tr class="block lg:table-row">
        <th
          class="mb-4 block space-y-3 text-start font-normal lg:mb-0 lg:table-cell">
          {
            pricingComparisonTogglerLabel && (
              <div
                class="opacity-70"
                set:html={markdownify(pricingComparisonTogglerLabel)}
              />
            )
          }
          <PricingToggle
            class="**:text-xs **:font-normal"
            uniqueId="group-b"
            plans={plans}
          />
        </th>
        {
          list.map((item) => (
            <th class="block w-full text-start lg:table-cell lg:w-auto">
              <div class="space-y-4 rounded-lg pt-6 pb-4 lg:overflow-hidden lg:rounded-none lg:border-0 lg:bg-transparent lg:px-8 lg:pt-10">
                <div class="flex items-center gap-2">
                  <h3
                    class="h4 font-medium"
                    set:html={markdownify(item.name.replace(" Plan", ""))}
                  />
                  {item.badge?.enable && (
                    <span
                      class:list={[
                        "inline-flex items-center rounded-full px-2 py-1 text-xs font-normal",
                        item.badge.variant === "popular" &&
                          "bg-blue-100 text-blue-700",
                        item.badge.variant === "new" &&
                          "bg-green-100 text-green-700",
                        item.badge.variant === "recommended" &&
                          "bg-purple-100 text-purple-700",
                      ]}>
                      {item.badge.label}
                    </span>
                  )}
                </div>

                {item.price?.map((price, usageIndex) => (
                  <div
                    data-plan={price.type.toLowerCase()}
                    class:list={[
                      "price-wrapper relative text-sm font-medium opacity-70",
                      {
                        active: selectedPlan?.label === price.type,
                      },
                      {
                        hidden:
                          selectedPlan?.label !== price.type && plans?.enable,
                      },
                      {
                        hidden: !plans?.enable && usageIndex !== 0,
                      },
                    ]}>
                    <AnimatedNumber
                      class="leading-none text-black"
                      animateOn="click"
                      transitionTime="1.2s"
                      content={price}
                    />
                    {price.typeAlternateValue && (
                      <span
                        class="leading-none"
                        set:html={markdownify(price.typeAlternateValue)}
                      />
                    )}
                  </div>
                ))}

                {item?.button?.enable && (
                  <CustomButton
                    class="btn-sm w-full [text-transform:unset] max-xl:px-0!"
                    {...item?.button}
                  />
                )}
              </div>
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody class="block lg:table-row-group [&_svg]:inline">
      {
        comparison?.map((item, index) => (
          <>
            {/* Group Name Row - eg: Features */}
            <tr class="block border-b lg:table-row">
              <td
                class:list={[
                  "block lg:table-cell lg:w-[400px]",
                  index !== 0 && "pt-8 lg:pt-16",
                  "py-4",
                ]}>
                <div class="flex items-center gap-2">
                  <h4
                    class="block text-lg font-medium text-black"
                    set:html={markdownify(item.label)}
                  />
                  <Popover content={item.popover} />
                </div>
              </td>
              {list.map((_) => (
                <td class="hidden py-4 lg:table-cell" />
              ))}
            </tr>

            {/* Each feature row - Mobile: Cards, Desktop: Table rows */}
            {item.list.map((i) => (
              <>
                {/* Mobile Layout - Card Style */}
                <tr class="block border-b py-4 lg:hidden">
                  <td class="pb-2 font-medium">
                    <h5
                      class="inline text-base font-normal"
                      set:html={markdownify(i.value)}
                    />
                    <Popover content={i.popover} />
                  </td>
                  <td class="block">
                    <div class="mt-2 grid grid-cols-2 gap-3 sm:grid-cols-3">
                      {i.included.map((includedIn, planIndex) => (
                        <div class="flex items-center gap-2 text-sm">
                          <span class="text-xs opacity-70">
                            {list[planIndex].name.replace(" Plan", "")}:
                          </span>
                          {includedIn === true ? (
                            <Icons icon="Check" class="text-primary" />
                          ) : includedIn === false ? (
                            <Icons icon="X" class="text-dark/15 text-lg" />
                          ) : (
                            <span class="font-medium">{includedIn}</span>
                          )}
                        </div>
                      ))}
                    </div>
                  </td>
                </tr>

                {/* Desktop Layout - Traditional Table */}
                <tr class="hidden border-b lg:table-row">
                  <td class="pb-2 font-medium">
                    <h5
                      class="inline w-fit py-4 text-base font-normal lg:w-[400px]"
                      set:html={markdownify(i.value)}
                    />
                    <Popover content={i.popover} />
                  </td>
                  {i.included.map((includedIn) => (
                    <td class="px-8 py-4 text-center text-sm">
                      {includedIn === true ? (
                        <Icons icon="Check" class="text-primary mx-auto" />
                      ) : includedIn === false ? (
                        <Icons icon="X" class="text-dark/15 text-lg" />
                      ) : (
                        includedIn
                      )}
                    </td>
                  ))}
                </tr>
              </>
            ))}
          </>
        ))
      }
    </tbody>
  </table>
</div>
