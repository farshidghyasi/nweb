---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import { getEntryCTM } from "@/lib/contentParser.astro";
import FunFact from "@/components/sections/FunFact.astro";
import HomeBanner from "@/components/sections/HomeBanner.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import FeaturesGrid from "@/components/sections/FeaturesGrid.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import InsightSection from "@/components/sections/InsightSection.astro";
import PricingSection from "@/components/sections/PricingSection.astro";
import TestimonialSection from "@/components/sections/TestimonialSection.astro";
import IntegrationSection from "@/components/sections/IntegrationSection.astro";
import FeaturesSectionTwo from "@/components/sections/FeaturesSectionTwo.astro";
import FeaturesRingLayout from "@/components/sections/FeaturesRingLayout.astro";

export function getStaticPaths() {
  return generatePaths();
}

const homepage = await getEntryCTM("homepage", "-index", Astro.currentLocale);
---

<Base {...homepage.data} homepage={true} hasGradientShape={false}>
  <HomeBanner />
  <FunFact />
  <FeaturesGrid />
  <InsightSection />
  <FeaturesSectionTwo />
  <FeaturesRingLayout />
  <IntegrationSection />
  <PricingSection />
  <TestimonialSection />
  <BlogSection />
  <CallToAction />
</Base>
